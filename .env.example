# Copy this file to .env.local and fill in your real key.
# Never put real API keys in .env.example (this file is usually committed to git).
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: enables login, resume file storage, and saved work.
# Create a Supabase project, run supabase/schema.sql, and create a private
# Storage bucket named "resumes".
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_RESUME_BUCKET=resumes
